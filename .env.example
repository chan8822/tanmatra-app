# Tanmatra Environment Configuration
# Copy to .env and fill in real values

# App
ENVIRONMENT=development
DEBUG=true

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./tanmatra.db
# DATABASE_URL=postgresql://user:password@localhost:5432/tanmatra

# Razorpay (test keys for development)
RAZORPAY_KEY_ID=rzp_test_demo_key
RAZORPAY_KEY_SECRET=demo_secret

# Gemini AI
GEMINI_API_KEY=

# JWT
JWT_SECRET=tanmatra-dev-secret-change-in-prod
JWT_EXPIRY_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Twilio (OTP) - optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
