# Tanmatra Production Environment Template
# Copy this file to .env and fill in your real values

# === App ===
ENVIRONMENT=production
APP_NAME=Tanmatra API
VERSION=1.0.0

# === Database ===
# For local dev: sqlite:///./tanmatra.db
# For production: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://tanmatra_user:your_strong_password@your-db-host:5432/tanmatra

# === Security ===
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# === CORS ===
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-frontend-domain.com,https://tanmatra.in

# === Razorpay (Payments) ===
# Test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# === Gemini AI (Recommendations) ===
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxx

# === Twilio (OTP SMS) ===
# Get from https://console.twilio.com/
TWILIO_SID=ACxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE=+1234567890

# === Enatega (Delivery) ===
# Contact Enatega for API access
ENATEGA_API_KEY=xxxxxxxxxxxxxxxx

# === Frontend Build ===
# Set this when building the frontend so it knows where the backend is
VITE_API_BASE=https://your-backend-domain.com
